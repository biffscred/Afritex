{% extends 'base.html.twig' %}

{% block title %}Liste des Produits
{% endblock %}

{% block body %}
	<h1>Liste de tous les Produits</h1>
	<ul>
		{% for product in products %}
			<li>
				<img src="{{ asset(product.images) }}" alt="{{ product.name }}" width="100" height="100">
				{{ product.name }}
				-
				{{ product.price }}
				€
				<a href="{{ path('addToCart', {'id': product.id}) }}">Ajouter au panier</a>
			</li>
		{% endfor %}
	</ul>
{% endblock %}
