{% extends 'base.html.twig' %}

{% block title %}Liste des catégories
{% endblock %}

{% block body %}
	<div
		class="container my-custom-container">
		{# Ajoutez une classe personnalisée ici #}
		<h1 class="text-center">Liste des Catégories</h1>
		<table class="table table-striped table-bordered">
			<thead class="thead-dark">
				<tr>
					<th>ID</th>
					<th>Nom</th>
					<th>Description</th>
					<th>Actions</th>
				</tr>
			</thead>
			<tbody>
				{% for category in categories %}
					<tr>
						<td>{{ category.id }}</td>
						<td>{{ category.name }}</td>
						<td>{{ category.description }}</td>
						<td>
							<a class="btn btn-primary" href="{{ path('app_category_show', {'id': category.id}) }}">Voir</a>
							<a class="btn btn-warning" href="{{ path('app_category_edit', {'id': category.id}) }}">Modifier</a>
						</td>
					</tr>
				{% else %}
					<tr>
						<td colspan="4" class="text-center">Aucun enregistrement trouvé</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
		<a class="btn btn-success" href="{{ path('app_category_new') }}">Créer une nouvelle catégorie</a>
	</div>
{% endblock %}
